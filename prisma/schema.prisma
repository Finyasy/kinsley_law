generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  name         String
  role         String         @default("admin")
  passwordHash String
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
  auditLogs    AuditLog[]

  @@index([role, isActive])
}

model AdminSession {
  id               Int       @id @default(autoincrement())
  sessionTokenHash String    @unique
  expiresAt        DateTime
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userAgent        String?
  ipAddress        String?
  adminUserId      Int
  adminUser        AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, expiresAt])
}

model AuditLog {
  id               Int        @id @default(autoincrement())
  action           String
  entityType       String
  entityId         String?
  summary          String
  metadata         Json?
  createdAt        DateTime   @default(now())
  actorAdminUserId Int?
  actorAdminUser   AdminUser? @relation(fields: [actorAdminUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@index([actorAdminUserId, createdAt])
}

model Attorney {
  id             Int            @id @default(autoincrement())
  name           String
  email          String         @unique
  phone          String
  bio            String
  position       String?
  specialization String?
  photoUrl       String?
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  practiceAreas  PracticeArea[]
  appointments   Appointment[]

  @@index([sortOrder])
}

model PracticeArea {
  id          Int                     @id @default(autoincrement())
  name        String                  @unique
  description String
  attorneyId  Int?
  sortOrder   Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  attorney    Attorney?               @relation(fields: [attorneyId], references: [id], onDelete: SetNull)
  highlights  PracticeAreaHighlight[]

  @@index([sortOrder])
}

model Contact {
  id            Int      @id @default(autoincrement())
  name          String
  email         String
  phone         String?
  service       String
  message       String
  status        String   @default("new")
  notificationStatus String?
  notificationDetail String?
  clientReplyStatus  String?
  clientReplyDetail  String?
  assignedTo    String?
  internalNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
}

model Appointment {
  id            Int       @id @default(autoincrement())
  name          String
  email         String
  phone         String
  date          DateTime
  time          String
  practiceArea  String
  description   String
  status        String    @default("new")
  notificationStatus String?
  notificationDetail String?
  clientReplyStatus  String?
  clientReplyDetail  String?
  assignedTo    String?
  internalNotes String?
  attorneyId    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  attorney      Attorney? @relation(fields: [attorneyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model PracticeAreaHighlight {
  id             Int          @id @default(autoincrement())
  label          String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  practiceAreaId Int
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id], onDelete: Cascade)

  @@unique([practiceAreaId, label])
  @@index([practiceAreaId, sortOrder])
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  quote     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
